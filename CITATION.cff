repository-code: "https://github.com/pjordanandrsn/grouped-nf4-gemm"
url: "https://cerinamroth.com/ml/"
license: MIT
keywords:
  - mixture-of-experts
  - quantization
  - nf4
  - mxfp4
  - triton
  - qlora
