{"info":{"author":"Jordan Anderson","author_email":null,"bugtrack_url":null,"classifiers":[],"description":"# expertsnbit\n\nThis package is an alias for [`experts4bit-qlora`](https://pypi.org/project/experts4bit-qlora/). `pip install expertsnbit` and `pip install experts4bit-qlora` are equivalent — this package ships no module of its own and simply depends on the real one. Canonical development happens at [pjordanandrsn/experts4bit-qlora](https://github.com/pjordanandrsn/experts4bit-qlora) — file issues there.\n","description_content_type":"text/markdown","docs_url":null,"download_url":null,"downloads":{"last_day":-1,"last_month":-1,"last_week":-1},"dynamic":["License-File"],"home_page":null,"keywords":null,"license":"MIT","license_expression":null,"license_files":["LICENSE"],"maintainer":null,"maintainer_email":null,"name":"expertsnbit","package_url":"https://pypi.org/project/expertsnbit/","platform":null,"project_url":"https://pypi.org/project/expertsnbit/","project_urls":{"Homepage":"https://cerinamroth.com/ml/","Real package (experts4bit-qlora)":"https://pypi.org/project/experts4bit-qlora/","Source":"https://github.com/pjordanandrsn/experts4bit-qlora"},"provides_extra":["train","serve","test"],"release_url":"https://pypi.org/project/expertsnbit/0.1.0/","requires_dist":["experts4bit-qlora>=0.3.0","experts4bit-qlora[train]>=0.3.0; extra == \"train\"","experts4bit-qlora[serve]>=0.3.0; extra == \"serve\"","experts4bit-qlora[test]>=0.3.0; extra == \"test\""],"requires_python":">=3.9","summary":"Alias for experts4bit-qlora — QLoRA fine-tuning of fused 4-bit Mixture-of-Experts on a single small GPU.","version":"0.1.0","yanked":false,"yanked_reason":null},"last_serial":39122801,"ownership":{"organization":null,"roles":[{"role":"Owner","user":"pjordanandrsn"}]},"releases":{"0.1.0":[{"comment_text":null,"core-metadata":{"sha256":"3f75bdc919c4a432b4ad65680c78e6490d988c9f90712d5e4a91326a923ffd87"},"digests":{"blake2b_256":"f18aac9d4a6251db410aa358c9498d0457108edbd1db0da461